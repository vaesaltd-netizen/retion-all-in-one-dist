{
  "manifest_version": 3,
  "name": "Retion All-in-One (CRM + Translator)",
  "version": "1.0.0",
  "description": "CRM + AI Translator cho Retion.ai - VAESA Trading Co., Ltd",

  "permissions": [
    "activeTab",
    "storage"
  ],

  "host_permissions": [
    "https://retion.ai/*",
    "https://*.retion.ai/*",
    "https://vaesa.soly.com.vn/*",
    "https://script.google.com/*",
    "https://vaesa.foxia.vn/*",
    "https://chatbox-ai.botbanhang.vn/*",
    "https://chatbox-service-v3.botbanhang.vn/*",
    "https://api.openai.com/*"
  ],

  "background": {
    "service_worker": "background.js"
  },

  "content_scripts": [
    {
      "matches": ["https://*.retion.ai/*", "https://retion.ai/*"],
      "js": ["crm/content.js"],
      "css": ["crm/content.css"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://*.retion.ai/*", "https://retion.ai/*"],
      "js": [
        "translator/lib/license-service.js",
        "translator/lib/language-detector.js",
        "translator/lib/language-worker-client.js",
        "translator/lib/openai-translator.js",
        "translator/content-scripts/inline-translator.js",
        "translator/content-scripts/inline-toolbar.js"
      ],
      "css": [
        "translator/styles/inline.css"
      ],
      "run_at": "document_idle"
    }
  ],

  "web_accessible_resources": [
    {
      "resources": ["crm/injected.js"],
      "matches": ["https://*.retion.ai/*", "https://retion.ai/*"]
    },
    {
      "resources": ["translator/lib/language-worker.js"],
      "matches": ["https://*.retion.ai/*", "https://retion.ai/*"]
    }
  ],

  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "assets/icon-16.png",
      "48": "assets/icon-48.png",
      "128": "assets/icon-128.png"
    },
    "default_title": "Retion All-in-One Settings"
  },

  "icons": {
    "16": "assets/icon-16.png",
    "48": "assets/icon-48.png",
    "128": "assets/icon-128.png"
  }
}
